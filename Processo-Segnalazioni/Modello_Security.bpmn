      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Pool_Iam_di" bpmnElement="Pool_Iam" isHorizontal="true">
        <dc:Bounds x="160" y="270" width="1620" height="210" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sgr_start_di" bpmnElement="sgr_start">
        <dc:Bounds x="230" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sgr_chal_di" bpmnElement="sgr_chal" bioc:stroke="#bdc3c7" color:border-color="#bdc3c7">
        <dc:Bounds x="290" y="320" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sgr_wait_risp_di" bpmnElement="sgr_wait_risp">
        <dc:Bounds x="440" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sgr_verifica_di" bpmnElement="sgr_verifica" bioc:stroke="#bdc3c7" color:border-color="#bdc3c7">
        <dc:Bounds x="510" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sgr_wait_segnalazione_di" bpmnElement="sgr_wait_segnalazione">
        <dc:Bounds x="650" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sgr_pseudo_di" bpmnElement="sgr_pseudo" bioc:stroke="#bdc3c7" color:border-color="#bdc3c7">
        <dc:Bounds x="720" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sgr_cattura_esito_comitato_di" bpmnElement="sgr_cattura_esito_comitato">
