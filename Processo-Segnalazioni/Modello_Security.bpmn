      <bpmndi:BPMNShape id="s_end_di" bpmnElement="s_end">
        <dc:Bounds x="970" y="147" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="cs1_di" bpmnElement="cs1">
        <di:waypoint x="266" y="165" />
        <di:waypoint x="290" y="165" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="cs2_di" bpmnElement="cs2">
