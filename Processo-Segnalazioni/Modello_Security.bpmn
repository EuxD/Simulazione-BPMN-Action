      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="ci8_di" bpmnElement="ci8">
        <di:waypoint x="1240" y="360" />
        <di:waypoint x="1310" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Pool_Com_di" bpmnElement="Pool_Com" isHorizontal="true">
        <dc:Bounds x="160" y="500" width="1620" height="470" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="c_start_di" bpmnElement="c_start">
        <dc:Bounds x="230" y="672" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="c_valutazione_di" bpmnElement="c_valutazione" bioc:stroke="#bdc3c7" color:border-color="#bdc3c7">
        <dc:Bounds x="300" y="650" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g1_di" bpmnElement="g1" isMarkerVisible="true">
        <dc:Bounds x="450" y="665" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g2_di" bpmnElement="g2" isMarkerVisible="true">
        <dc:Bounds x="550" y="665" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g3_di" bpmnElement="g3">
        <dc:Bounds x="650" y="665" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="c_doc_di" bpmnElement="c_doc" bioc:stroke="#bdc3c7" color:border-color="#bdc3c7">
        <dc:Bounds x="760" y="550" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="c_cont_di" bpmnElement="c_cont" bioc:stroke="#bdc3c7" color:border-color="#bdc3c7">
        <dc:Bounds x="760" y="750" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g4_di" bpmnElement="g4">
        <dc:Bounds x="920" y="665" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g5_di" bpmnElement="g5" isMarkerVisible="true">
        <dc:Bounds x="1020" y="665" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1052" y="715" width="31" height="14" />
        </bpmndi:BPMNLabel>
